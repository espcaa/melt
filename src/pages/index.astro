---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Steps from "../components/Steps.astro";
import Faq from "../components/FAQ.astro";
import ArrowsImg from "../assets/arrows.png";
import { Image } from "astro:assets";
import Examples from "../components/Examples.astro";
---

<Layout title="Melt">
    <div class="absoluteDocBtn">
        <a href="https://docs.google.com/document/d/1Xo9n8s0l3j2mLh7e5kKZtHqj8v6u9yXo5z8a9b0c1/edit?usp=sharing" target="_blank" rel="noopener noreferrer">
            <button class="docbtn"><span class="material-icons icon">description</span> <p class="fancy">Docs</p></button>
        </a>
        <Image src={ArrowsImg} alt="arrows" class="imageAbsoluteButton" />
    </div>
    <canvas id="scene-canvas"></canvas>
    <div class="mainContainer">
        <div class="title">
            <h1>Melt</h1>
            <p class="subtitle">
                Make a funny pcb with smd components and get a hotplate to <em>melt</em> assemble it!
            </p>
        </div>
        <div class="cta">
            <div class="rsvp">
                <input type="email" id="rsvp-input" placeholder="you@email.com" />
                <button class="rsvp" id="rsvp-button">RSVP!</button>
            </div>
            <a href="">
                <button class="btn">Submit now!</button>
            </a>
        </div>
        <div class="content">
            <Steps />
        </div>
        <Examples />
        <Faq />

    </div>
    <Footer />
</Layout>

<style>
    #scene-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: -1;
    }

    .title {
        margin-left: 1rem;
        font-family: "Satoshi";
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    h1 {
        position: relative;
        color: #333;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        font-size: 10rem;
        margin-bottom: 0.3rem;
        margin-top: 4rem;
    }

    h1::before {
        content: "";
        position: absolute;
        inset: 0;
        background-color: var(--primary-color);
        border-radius: 0.5rem;
        transform: rotate(5deg) scalex(1.2);
        z-index: -1;
    }

    .subtitle {
        color: #555;
        font-family: "Crimson", serif;
        font-size: 1.5rem;
        max-width: 600px;
        text-align: center;
    }

    em {
        text-decoration: line-through black;
    }

    .cta {
        margin-top: 2rem;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        margin-bottom: 4rem;
    }

    input {
        padding: 0.75rem 1rem;
        font-size: 1rem;
        border: 2px solid var(--primary-color);
        border-radius: 0.5rem;
        margin-right: 1rem;
        width: 250px;
    }

    .rsvp {
        display: flex;
        align-items: center;
        margin-bottom: 1rem;
    }

    button.rsvp {
        background-color: var(--primary-color);
        color: #333;
        border: none;
        padding: 1rem 2rem;
        font-size: 1.25rem;
        border-radius: 0.5rem;
        cursor: pointer;
        margin: 0;
    }

    button.rsvp:hover {
        background-color: var(--primary-color-hover);
    }

    button.rsvp:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    button.btn {
        background-color: #fff2c7;
        color: #333;
        border: none;
        padding: 1rem 2rem;
        font-size: 1.25rem;
        border-radius: 0.5rem;
        cursor: pointer;
    }

    .btn:hover {
        background-color: #ffe0a3;
    }

    a {
        text-decoration: none;
    }

    .absoluteDocBtn {
        position: fixed;
        display: flex;
        align-items: center;
        top: 1rem;
        right: 1rem;
        z-index: 10;
        flex-direction: row;
    }

    .docbtn:hover {
        background-color: var(--primary-color-hover);
    }

    .imageAbsoluteButton {
        position: absolute;
        bottom: -70px;
        left: -70px;

        width: 100px;
        height: 100px;
    }

    .icon {
        font-size: 1.5rem;
        vertical-align: middle;
        margin-right: 0.5rem;
    }

    .docbtn {
        background-color: var(--primary-color);
        color: #333;
        border: none;
        padding: 0.3rem 1.5rem;
        font-size: 1rem;
        border-radius: 0.5rem;
        cursor: pointer;
        display: flex;
        align-items: center;
    }

    p.fancy {
        font-family: "Satoshi";
        font-size : 1.5rem;
        margin-bottom: 0.5rem;
        margin-top: 0.5rem;
    }

    .mainContainer {
        padding-bottom: 70vh;
        margin-bottom: 0vh;
    }


</style>

<script>
    import * as THREE from "three";
    import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const canvas = document.getElementById("scene-canvas") as HTMLCanvasElement;
    const renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: true,
        antialias: true,
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();

    let camera: THREE.PerspectiveCamera | THREE.Camera =
        new THREE.PerspectiveCamera(
            45,
            window.innerWidth / window.innerHeight,
            0.1,
            1000,
        );
    camera.position.set(0, 2, 5);

    const ambientLight = new THREE.AmbientLight(0xffffff, 1);
    scene.add(ambientLight);
    const dirLight = new THREE.DirectionalLight(0xffffff, 2);
    dirLight.position.set(5, 10, 7);
    scene.add(dirLight);

    let mixer: THREE.AnimationMixer | null = null;
    let actions: THREE.AnimationAction[] = [];
    let animationDuration = 1;

    const gradientMap = new THREE.DataTexture(
        new Uint8Array([60, 120, 180, 255]),
        4, 1, THREE.RedFormat,
    );
    gradientMap.minFilter = THREE.NearestFilter;
    gradientMap.magFilter = THREE.NearestFilter;
    gradientMap.needsUpdate = true;

    const loader = new GLTFLoader();
    loader.load("/pcbboard.glb", (gltf) => {
        gltf.scene.traverse((child) => {
            if (child instanceof THREE.Mesh && child.material) {
                const old = child.material as THREE.MeshStandardMaterial;
                child.material = new THREE.MeshToonMaterial({
                    color: old.color,
                    map: old.map,
                    gradientMap,
                });
            }
        });

        scene.add(gltf.scene);

        if (gltf.cameras.length > 0) {
            camera = gltf.cameras[0];
            if (camera instanceof THREE.PerspectiveCamera) {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
            }
        }

        if (gltf.animations.length > 0) {
            mixer = new THREE.AnimationMixer(gltf.scene);
            for (const clip of gltf.animations) {
                const action = mixer.clipAction(clip);
                action.play();
                actions.push(action);
            }
            animationDuration = Math.max(
                ...gltf.animations.map((a) => a.duration),
            );

            ScrollTrigger.create({
                trigger: ".mainContainer",
                start: "top top",
                end: "bottom bottom",
                scrub: true,
                onUpdate: (self) => {
                    const targetTime = self.progress * animationDuration;
                    for (const action of actions) {
                        action.time = targetTime;
                    }
                    mixer!.update(0);
                },
                onLeave: () => {
                    canvas.style.position = "absolute";
                    canvas.style.top = `${window.scrollY}px`;
                },
                onEnterBack: () => {
                    canvas.style.position = "fixed";
                    canvas.style.top = "0";
                },
            });
        }

        render();
    });

    function render() {
        requestAnimationFrame(render);
        renderer.render(scene, camera);
    }

    window.addEventListener("resize", () => {
        renderer.setSize(window.innerWidth, window.innerHeight);
        if (camera instanceof THREE.PerspectiveCamera) {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
        }
    });

    // general gsap anim stuff

    const tl = gsap.timeline();
    tl.from(".title h1", {
        y: -100,
        opacity: 0.5,
        stagger: 0.2,
        ease: "bounce.out(1, 0.3)",
        duration: 0.6,
    }).from(".cta" + " .btn", {
        scale: 0.8,
        opacity: 0,
        ease: "back.out(1.7)",
        duration: 0.5,
    }, "-=0.3")

    // rsvp

    const rsvpInput = document.getElementById("rsvp-input") as HTMLInputElement;
    const rsvpButton = document.getElementById("rsvp-button") as HTMLButtonElement;

    function shake(el: HTMLElement) {
        gsap.fromTo(el, { x: -6 }, {
            x: 6, duration: 0.08, ease: "power1.inOut",
            yoyo: true, repeat: 5,
        });
    }

    rsvpButton.addEventListener("click", async () => {
        const email = rsvpInput.value.trim();

        if (!email || !email.includes("@")) {
            shake(rsvpInput);
            return;
        }

        rsvpButton.disabled = true;
        rsvpButton.textContent = "Sending...";

        try {
            const res = await fetch("/api/rsvp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email }),
            });

            if (res.ok) {
                rsvpInput.value = "";
                rsvpButton.textContent = "Done!";
                gsap.to(rsvpButton, { backgroundColor: "#4caf50", color: "#fff", duration: 0.3 });
                setTimeout(() => {
                    gsap.to(rsvpButton, { backgroundColor: "#f8abff", color: "#333", duration: 0.3 });
                    rsvpButton.textContent = "RSVP!";
                    rsvpButton.disabled = false;
                }, 2000);
            } else {
                shake(rsvpInput);
                rsvpButton.disabled = false;
                rsvpButton.textContent = "RSVP!";
            }
        } catch {
            shake(rsvpInput);
            rsvpButton.disabled = false;
            rsvpButton.textContent = "RSVP!";
        }
    });

</script>
