---
const faqs = [
    { q: "Can I really get this for free?", a: "Yes! This is completely free for all teens aged 18 or under." },
    { q: "Do I need experience?", a: "Nope! Beginners are totally welcome. We'll organize calls to help you out and we will have guides!" },
    { q: "How much time do I need to spend on this?", a: "We expect participants to spend around 8-12 hours on their project! All of your time needs to be recorded with lapse. It's fine if you go faster but your project needs to be unique and polished!"},
    { q: "Can I make multiple projects?", a: "Yes! You can & are encouraged to make multiple projects! Try to push yourself a little further everytime!"}
];
---

<section class="faq">
    <h2>FAQ</h2>
    {faqs.map(({ q, a }) => (
        <details>
            <summary>{q}</summary>
            <p>{a}</p>
        </details>
    ))}
</section>

<style>
    .faq {
        max-width: 700px;
        margin: 4rem auto;
        padding: 0 1rem;
    }

    .faq h2 {
        font-family: "Satoshi";
        font-size: 2rem;
        color: #333;
        text-align: center;
        margin-bottom: 2rem;
    }

    details {
        background: #fff;
        border-radius: 1rem;
        padding: 0;
        margin-bottom: 1rem;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        overflow: hidden;
    }

    summary {
        font-family: "Satoshi";
        font-size: 1.1rem;
        font-weight: 700;
        color: #333;
        padding: 1.25rem 1.5rem;
        cursor: pointer;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    summary::after {
        content: "+";
        font-size: 1.5rem;
        color: #f8abff;
        transition: transform 0.2s;
    }

    details[open] summary::after {
        content: "−";
    }

    summary::-webkit-details-marker {
        display: none;
    }

    details p {
        font-family: "Crimson", serif;
        font-size: 1.05rem;
        color: #666;
        line-height: 1.6;
        padding: 0 1.5rem 1.25rem;
        margin: 0;
        overflow: hidden;
    }
</style>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const details = document.querySelectorAll(".faq details");
    gsap.from(details, {
        y: 40,
        opacity: 0,
        duration: 0.6,
        stagger: 0.12,
        ease: "back.out(1.4)",
        scrollTrigger: {
            trigger: ".faq",
            start: "top 80%",
        },
    });

    details.forEach((el) => {
        const summary = el.querySelector("summary")!;
        const content = el.querySelector("p")!;

        summary.addEventListener("click", (e) => {
            e.preventDefault();

            if (el.hasAttribute("open")) {
                gsap.to(content, {
                    height: 0,
                    opacity: 0,
                    duration: 0.35,
                    ease: "power2.inOut",
                    onComplete: () => {
                        el.removeAttribute("open");
                        gsap.set(content, { clearProps: "all" });
                        ScrollTrigger.refresh();
                    },
                });
                gsap.to(summary.querySelector("::after") ?? summary, {
                    rotation: 0,
                    duration: 0.3,
                });
            } else {
                el.setAttribute("open", "");
                const fullHeight = content.scrollHeight;
                gsap.fromTo(
                    content,
                    { height: 0, opacity: 0 },
                    {
                        height: fullHeight,
                        opacity: 1,
                        duration: 0.4,
                        ease: "power2.out",
                        onComplete: () => ScrollTrigger.refresh(),
                    }
                );
            }
        });
    });
</script>
