---
const { title = "smelt ysws!" } = Astro.props;
import Hackclub from "../components/Hackclub.astro";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <Hackclub />
        <main>
            <slot />
        </main>
    </body>
</html>

<style is:global>


    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        display: flow-root;
        font-family: "Crimson", sans-serif;
        overflow-x: hidden;
    }
    main {
        margin: 0 auto;
    }

</style>
