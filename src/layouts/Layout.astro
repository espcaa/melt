---
const {
    title = "Smelt ysws!",
    description = "Make a funny pcb with smd components and get a hotplate to (melt) assemble it!",
    image = "/og.png",
} = Astro.props;
import Hackclub from "../components/Hackclub.astro";

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://smelt.hackclub.com");
const ogImageURL = new URL(image, canonicalURL);
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />

        <!-- open thingy;; -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL.href} />

        <!-- twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL.href} />
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    </head>
    <body>
        <Hackclub />
        <main>
            <slot />
        </main>
    </body>
</html>

<style is:global>

    @font-face {
        font-family: "Satoshi";
        src: url("/satoshi.woff2") format("woff2");
        font-weight: 800;
        font-display: swap;
    }

    @font-face {
        font-family: "Crimson";
        src: url("/crimson.ttf") format("truetype");
        font-weight: 400;
        font-display: swap;
    }

    @font-face {
        font-family: "Playfair";
        src: url("/playfair.ttf") format("truetype");
        font-weight: 400;
        font-display: swap;
    }

    :root {
        --primary-color: #f8abff;
        --primary-color-hover: #f6a3f9;
        --secondary-color: #fff2c7;
        --background-color: #ffffff;
        --text-color: #333;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        display: flow-root;
        font-family: "Crimson", sans-serif;
        overflow-x: hidden;
        background-image:
            linear-gradient(rgba(0, 0, 0, 0.06) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 0, 0, 0.06) 1px, transparent 1px);
        background-size: 40px 40px;
        background-color: #ffffff;
    }

    main {
        margin: 0 auto;
    }

    .mainContainer {
        max-width: 800px;
        margin: 0 auto;
        margin-top: 70px;
        padding: 20px;
    }

</style>
